# ============================================================
# EO Policy Skills Dashboard — Environment Variables
# ============================================================
# Copy this file to .env for local development.
# On Railway, set these in the service Variables tab.
# NEVER commit a .env file with real secrets to Git.
# ============================================================

# ------------------------------------
# OpenAI (optional)
# ------------------------------------
# Enables semantic search via text-embedding-3-small.
# Leave unset for 100% offline SBERT mode.
# Approximate cost: $0.01–0.05 per 30-PDF corpus (first run only;
# subsequent runs are free thanks to the embedding cache).
# OPENAI_API_KEY=sk-proj-...

# ------------------------------------
# PDF folder (recommended for large corpora)
# ------------------------------------
# Absolute path to a directory of PDF policy documents on the server.
# On Railway: mount a volume at /data, copy PDFs to /data/pdfs.
# The Streamlit sidebar will pre-fill this value automatically.
# PDF_FOLDER=/data/pdfs

# ------------------------------------
# Cache directory (persistent embeddings + outputs)
# ------------------------------------
# Where embedding vectors (.npy) and auto-saved exports are stored.
# On Railway: mount a volume at /data, then set:
#   CACHE_DIR=/data/cache
# Without a volume the cache is ephemeral (.cache/ folder in the container).
# CACHE_DIR=/data/cache
